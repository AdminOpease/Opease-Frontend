# Server
PORT=4000
NODE_ENV=development

# PostgreSQL (AWS RDS in production)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=opease
DB_USER=opease
DB_PASSWORD=opease_dev

# AWS Cognito
COGNITO_USER_POOL_ID=eu-west-2_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
COGNITO_REGION=eu-west-2

# AWS S3
S3_BUCKET=opease-documents
S3_REGION=eu-west-2

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:8081
